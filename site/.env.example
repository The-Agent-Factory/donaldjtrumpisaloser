# Site URL (used for canonical URLs and sitemap)
NEXT_PUBLIC_SITE_URL=https://donaldjtrumpisaloser.com

# Monetization (all optional — components render nothing if unset)

# Google AdSense client ID, e.g. ca-pub-1234567890123456
NEXT_PUBLIC_ADSENSE_CLIENT=

# Substack newsletter — full URL, e.g. https://donaldjtrumpisaloser.substack.com
NEXT_PUBLIC_SUBSTACK_URL=

# Donorbox campaign ID (for site-operated drives)
NEXT_PUBLIC_DONORBOX_ID=

# Bookshop.org affiliate ID
NEXT_PUBLIC_BOOKSHOP_ID=

# Gelato print-on-demand store URL
NEXT_PUBLIC_GELATO_STORE_URL=

# Submission/tip form endpoint (e.g. Formspree)
NEXT_PUBLIC_FORM_ENDPOINT=
